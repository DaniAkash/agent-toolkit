{
  "name": "acpx-ai-harness",
  "version": "0.0.1",
  "description": "Vercel AI SDK v7 HarnessV1 adapter for acpx, bring any ACP agent (Claude, Codex, Gemini, Copilot, Cursor) to the AI SDK Harnesses ecosystem.",
  "license": "MIT",
  "author": "Dani Akash",
  "homepage": "https://github.com/DaniAkash/acpx/tree/main/packages/acpx-ai-harness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaniAkash/acpx.git",
    "directory": "packages/acpx-ai-harness"
  },
  "bugs": "https://github.com/DaniAkash/acpx/issues",
  "keywords": [
    "ai-sdk",
    "ai-sdk-harness",
    "harness",
    "harness-adapter",
    "acp",
    "agent-client-protocol",
    "acpx",
    "claude-code",
    "codex",
    "gemini",
    "copilot",
    "cursor"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bunup && bun run copy-bridge-assets",
    "copy-bridge-assets": "node --input-type=module -e \"import { copyFile, mkdir } from 'node:fs/promises'; await mkdir('dist/bridge', { recursive: true }); await copyFile('src/bridge/package.json', 'dist/bridge/package.json');\"",
    "dev": "bunup --watch",
    "test": "bun test test/unit",
    "test:e2e": "bun run build && bun test test/e2e",
    "test:smoke": "SMOKE_AGENTS=all bun run test:e2e",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/harness": ">=1.0.0-canary.10",
    "acpx": ">=0.8.0",
    "ai": ">=7.0.0-beta.0"
  },
  "dependencies": {
    "ws": "^8.20.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@ai-sdk/harness": "1.0.0-canary.10",
    "@ai-sdk/provider": "4.0.0-canary.18",
    "@ai-sdk/provider-utils": "5.0.0-canary.48",
    "@ai-sdk/sandbox-vercel": "1.0.0-canary.10",
    "@types/ws": "^8",
    "acpx": "^0.8.0",
    "acpx-test-helpers": "workspace:*",
    "bunup": "^0.16.31",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
