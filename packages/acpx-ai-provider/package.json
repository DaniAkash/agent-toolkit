{
  "name": "acpx-ai-provider",
  "version": "0.0.6",
  "description": "Vercel AI SDK provider on top of acpx/runtime — bring any ACP agent (Claude, Codex, Gemini, Copilot, Cursor…) to AI SDK with one install.",
  "license": "MIT",
  "author": "Dani Akash",
  "homepage": "https://github.com/DaniAkash/acpx/tree/main/packages/acpx-ai-provider#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaniAkash/acpx.git",
    "directory": "packages/acpx-ai-provider"
  },
  "bugs": "https://github.com/DaniAkash/acpx/issues",
  "keywords": [
    "ai-sdk",
    "ai-sdk-provider",
    "acp",
    "agent-client-protocol",
    "acpx",
    "claude-code",
    "codex",
    "gemini",
    "copilot",
    "cursor"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "test": "bun test",
    "test:smoke": "SMOKE_AGENTS=all bun test test/e2e",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "acpx": ">=0.8.0",
    "ai": ">=7.0.0-beta.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^4.0.0-beta.14",
    "@ai-sdk/provider-utils": "^5.0.0-beta.30",
    "acpx": "^0.8.0",
    "ai": "^7.0.0-beta.116",
    "bunup": "^0.16.31",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
