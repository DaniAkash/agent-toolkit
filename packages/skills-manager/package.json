  "description": "Programmatic skill workspace + agent-link manager for ACP coding agents. Wraps vercel-labs/skills for use as a library.",
  "license": "MIT",
  "author": "Dani Akash",
  "homepage": "https://github.com/DaniAkash/acpx/tree/main/packages/skills-manager#readme",
